# Atlas Environment Variables
# Copy to .env and customize for your deployment

# ============================================
# Configuration File
# ============================================
CONFIG_PATH=config.yaml              # Path to configuration file

# ============================================
# Cache Configuration (Optional Overrides)
# ============================================
# These override config.yaml settings
# CACHE_TYPE=redis                   # Options: memory, redis
# REDIS_ADDR=redis:6379              # Redis server address (for Docker use service name)
# REDIS_PASSWORD=                    # Redis password (if required)

# ============================================
# Feature Flags (Optional Overrides)
# ============================================
# MULTI_CLUSTER=true                 # Override multi-cluster mode from config.yaml

# ============================================
# Logging
# ============================================
LOG_LEVEL=info                       # Options: debug, info, warn, error

# ============================================
# Notes
# ============================================
# Primary configuration should be in config.yaml
# Use .env for environment-specific overrides only
# For Docker Compose: use service names (e.g., redis:6379)
# For local dev: use localhost (e.g., localhost:6379)
